name: Publish to npm

on:
  push:
    tags:
      - 'v*'  # Wird bei Tags wie v1.0.0, v2.3.4 etc. ausgelöst
  workflow_dispatch:  # Erlaubt manuelles Starten über GitHub UI
jobs:
  publish:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4   # Checkt dein Repository aus
      
      - uses: actions/setup-node@v4
        with:
          node-version: 20
          registry-url: 'https://registry.npmjs.org'
      
      - run: npm ci         # Installiert Abhängigkeiten
      - run: npm publish    # Veröffentlicht das Paket
        env:
          NODE_AUTH_TOKEN: ${{ secrets.NPM_TOKEN }}  # Nutzt den gespeicherten npm-Token
